# cp .env.example .env して値を設定してください。.env はgit管理対象外です。

AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# terraform apply の出力 job_queue_url / bucket_name を設定
SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/<account-id>/voice-dataset-job-queue
S3_BUCKET=voice-dataset-<account-id>

ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-5

WHISPER_MODEL=small
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
WORK_DIR=./work

# 音質ゲート: これを下回るソース音源は文字起こしを行わずerror/へ振り分ける
MIN_BITRATE_KBPS=96
MIN_SAMPLE_RATE_HZ=32000

# 同時に処理するファイル数(並行Workerプロセス数)。PCのCPUコア数に応じて調整。
WORKER_CONCURRENCY=1
